{#
  Dispatcher Macro
  Renders Craft CMS Field Layouts dynamically using Bootstrap 5 and HTMX.
#}

{% macro renderLayout(entry, depth = 0) %}
  {% import _self as self %}
  {# Prevent infinite recursion with nested Entries fields #}
  {% if depth > 3 %}
    <div class="alert alert-danger">Recursion depth limit reached.</div>
  {% else %}

  {% set layout = entry.getType().getFieldLayout() %}
  {% set tabs = layout.getTabs() %}

  {% if tabs|length > 1 %}
    {# Render Bootstrap Nav Tabs #}
    <ul class="nav nav-tabs mb-4" id="entryTabs-{{ entry.id }}" role="tablist">
      {% for tab in tabs %}
        <li class="nav-item" role="presentation">
          <button class="nav-link {% if loop.first %}active{% endif %}" id="tab-{{ tab.id }}" data-bs-toggle="tab" data-bs-target="#tab-pane-{{ tab.id }}" type="button" role="tab" aria-controls="tab-pane-{{ tab.id }}" aria-selected="{{ loop.first ? 'true' : 'false' }}">
            {{ tab.name }}
          </button>
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  <div class="tab-content" id="entryTabContent-{{ entry.id }}">
    {% for tab in tabs %}
      <div class="tab-pane fade {% if loop.first %}show active{% endif %}" id="tab-pane-{{ tab.id }}" role="tabpanel" aria-labelledby="tab-{{ tab.id }}" tabindex="0">
        
        <div class="row g-3">
          {% for element in tab.getElements() %}
            {% if element and element.isVisible(entry) %}
              {% set classType = className(element) %}
              {% set widthClass = 'col-12' %}

              <div class="{{ widthClass }} mb-3">
                {% if classType == 'craft\\fieldlayoutelements\\Tip' or classType == 'craft\\fieldlayoutelements\\Warning' %}
                  {% set alertClass = classType == 'craft\\fieldlayoutelements\\Warning' ? 'alert-warning' : 'alert-info' %}
                  <div class="alert {{ alertClass }} d-flex align-items-center" role="alert">
                    <div>
                      {{ element.getHtml(entry)|raw }}
                    </div>
                  </div>

                {% elseif classType == 'craft\\fieldlayoutelements\\Heading' %}
                  <h3 class="mt-4 mb-2">{{ element.heading }}</h3>

                {% elseif classType == 'craft\\fieldlayoutelements\\LineBreak' %}
                  <br>

                {% elseif classType == 'craft\\fieldlayoutelements\\CustomField' %}
                  {% set field = element.getField() %}
                  <div class="alert alert-secondary">Custom field stubbed {{ field ? className(field) : 'no field' }}.</div>

                {% elseif classType == 'craft\\fieldlayoutelements\\HorizontalRule' %}
                  <hr>

                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
        
      </div>
    {% endfor %}
  </div>
  {% endif %}
{% endmacro %}
