{#
  Dispatcher Macro
  Renders Craft CMS Field Layouts dynamically using Bootstrap 5 and HTMX.
#}

{% macro renderLayout(entry, depth = 0) %}
  {% import _self as self %}
  {# Prevent infinite recursion with nested Entries fields #}
  {% if depth > 3 %}
    <div class="alert alert-danger">Recursion depth limit reached.</div>
  {% elseif entry is not defined or not entry %}
    <!-- Empty element passed to renderLayout -->
  {% elseif getattr(entry, 'getFieldLayout', null) is null and entry.getFieldLayout is not defined %}
    <div class="alert alert-warning">Unable to render layout: Component does not support field layouts.</div>
  {% else %}

  {% set layout = entry.getFieldLayout() %}
  {% set tabs = layout.getTabs() %}

  {% if tabs|length > 1 %}
    {# Render Bootstrap Nav Tabs #}
    <ul class="nav nav-tabs mb-4" id="entryTabs-{{ entry.id }}" role="tablist">
      {% for tab in tabs %}
        <li class="nav-item" role="presentation">
          <button class="nav-link {% if loop.first %}active{% endif %}" id="tab-{{ tab.id }}" data-bs-toggle="tab" data-bs-target="#tab-pane-{{ tab.id }}" type="button" role="tab" aria-controls="tab-pane-{{ tab.id }}" aria-selected="{{ loop.first ? 'true' : 'false' }}">
            {{ tab.name }}
          </button>
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  <div class="tab-content" id="entryTabContent-{{ entry.id }}">
    {% for tab in tabs %}
      <div class="tab-pane fade {% if loop.first %}show active{% endif %}" id="tab-pane-{{ tab.id }}" role="tabpanel" aria-labelledby="tab-{{ tab.id }}" tabindex="0">
        
        <div class="row g-3">
          {% for element in tab.getElements() %}
            {% if element %}
              {% set classType = className(element) %}
              {% set widthClass = 'col-12' %}

              <div class="{{ widthClass }} mb-3">
                {% if classType == 'craft\\fieldlayoutelements\\Tip' or classType == 'craft\\fieldlayoutelements\\Warning' %}
                  {% set alertClass = classType == 'craft\\fieldlayoutelements\\Warning' ? 'alert-warning' : 'alert-info' %}
                  <div class="alert {{ alertClass }} d-flex align-items-center" role="alert">
                    <div>
                      {{ element.getHtml(entry)|raw }}
                    </div>
                  </div>

                {% elseif classType == 'craft\\fieldlayoutelements\\Heading' %}
                  <h3 class="mt-4 mb-2">{{ element.heading }}</h3>

                {% elseif classType == 'craft\\fieldlayoutelements\\LineBreak' %}
                  <br>

                {% elseif classType == 'craft\\fieldlayoutelements\\HorizontalRule' %}
                  <hr>

                {% elseif classType == 'craft\\fieldlayoutelements\\CustomField' %}
                  {# Use getFieldByUid to prevent throwing InvalidConfigException which triggers Twig Error reflection crash #}
                  {% set field = craft.app.fields.getFieldByUid(element.fieldUid) %}
                  {% if field %}
                  {% set fieldClass = className(field) %}
                  {% set value = entry.getFieldValue(field.handle) %}
                  
                  <div class="form-group">
                    <label class="form-label fw-bold" for="fields-{{ field.handle }}">
                      {{ field.name }}
                      {% if element.required %}<span class="text-danger">*</span>{% endif %}
                    </label>
                    
                    {% if element.instructions %}
                      <div class="form-text mb-2">{{ element.instructions|t('site') }}</div>
                    {% endif %}

                    {# Text/Plain Field #}
                    {% if fieldClass == 'craft\\fields\\PlainText' or fieldClass == 'craft\\fields\\Email' or fieldClass == 'craft\\fields\\Url' or fieldClass == 'craft\\fields\\Number' %}
                      {% set inputType = 'text' %}
                      {% if fieldClass == 'craft\\fields\\Email' %}{% set inputType = 'email' %}{% endif %}
                      {% if fieldClass == 'craft\\fields\\Url' %}{% set inputType = 'url' %}{% endif %}
                      {% if fieldClass == 'craft\\fields\\Number' %}{% set inputType = 'number' %}{% endif %}
                      
                      <input type="{{ inputType }}" 
                             id="fields-{{ field.handle }}" 
                             name="fields[{{ field.handle }}]" 
                             class="form-control {% if entry.hasErrors(field.handle) %}is-invalid{% endif %}"
                             value="{{ value }}"
                             {% if element.required %}required{% endif %}>
                      
                      {% if entry.hasErrors(field.handle) %}
                        <div class="invalid-feedback d-block">
                          {{ entry.getErrors(field.handle)|join(', ') }}
                        </div>
                      {% endif %}

                    {# Entries, ContentBlock & Matrix Fields #}
                    {% elseif fieldClass == 'craft\\fields\\Entries' or fieldClass == 'craft\\fields\\ContentBlock' or fieldClass == 'craft\\fields\\Matrix' %}
                      {% set displayMode = 'list' %}
                      {% set queryItems = value and value.all is defined ? value.all() : (value is iterable ? value : []) %}
                      
                      {% if displayMode == 'cards' or displayMode == 'cards-grid' %}
                        <div class="row row-cols-1 row-cols-md-2 g-3 mt-1">
                          {% for relatedEntry in queryItems %}
                            <div class="col">
                              <div class="card h-100 position-relative">
                                {# Slideout trigger for editing entry #}
                                {% include "_components/slideout" ignore missing with { entry: relatedEntry } %}
                                
                                <div class="card-body">
                                  <h5 class="card-title pr-4">{{ relatedEntry.title ?? 'Item ' ~ loop.index }}</h5>
                                  <div class="card-text">
                                    {{ self.renderLayout(relatedEntry, depth + 1) }}
                                  </div>
                                </div>
                              </div>
                            </div>
                          {% endfor %}
                        </div>
                      {% else %}
                        <ul class="list-group mt-1">
                          {% for relatedEntry in queryItems %}
                            <li class="list-group-item d-flex justify-content-between align-items-start">
                              <div class="ms-2 me-auto w-100">
                                <div class="fw-bold mb-2">{{ relatedEntry.title ?? 'Item ' ~ loop.index }}</div>
                                {{ self.renderLayout(relatedEntry, depth + 1) }}
                              </div>
                              {# Slideout trigger #}
                              {% include "_components/slideout" ignore missing with { entry: relatedEntry, isList: true } %}
                            </li>
                          {% endfor %}
                        </ul>
                      {% endif %}

                    {# Lightswitch Field #}
                    {% elseif fieldClass == 'craft\\fields\\Lightswitch' %}
                      <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" role="switch" id="fields-{{ field.handle }}" name="fields[{{ field.handle }}]" value="1" {% if value %}checked{% endif %}>
                        <label class="form-check-label" for="fields-{{ field.handle }}">Enable</label>
                      </div>

                    {# Select Fields (Dropdown / MultiSelect) #}
                    {% elseif fieldClass == 'craft\\fields\\Dropdown' or fieldClass == 'craft\\fields\\MultiSelect' %}
                      <select class="form-select" id="fields-{{ field.handle }}" name="fields[{{ field.handle }}]{% if fieldClass == 'craft\\fields\\MultiSelect' %}[]{% endif %}" {% if fieldClass == 'craft\\fields\\MultiSelect' %}multiple{% endif %} {% if element.required %}required{% endif %}>
                        {% if not element.required and fieldClass == 'craft\\fields\\Dropdown' %}
                          <option value="">{{ field.emptyOptionLabel|default('Select an option') }}</option>
                        {% endif %}
                        {% for option in field.options %}
                          {% set isSelected = false %}
                          {% if value %}
                            {% if fieldClass == 'craft\\fields\\MultiSelect' %}
                              {% set iterableValue = value|length ? value : [] %}
                              {% for val in iterableValue %}
                                {% if val.value is defined and val.value == option.value %}{% set isSelected = true %}{% endif %}
                              {% endfor %}
                            {% else %}
                              {% if value.value is defined and value.value == option.value %}{% set isSelected = true %}{% endif %}
                            {% endif %}
                          {% endif %}
                          <option value="{{ option.value }}" {% if isSelected %}selected{% endif %}>{{ option.label }}</option>
                        {% endfor %}
                      </select>

                    {# Radio Buttons #}
                    {% elseif fieldClass == 'craft\\fields\\RadioButtons' %}
                      <div class="mt-2">
                        {% for option in field.options %}
                          <div class="form-check">
                            <input class="form-check-input" type="radio" name="fields[{{ field.handle }}]" id="fields-{{ field.handle }}-{{ loop.index }}" value="{{ option.value }}" {% if value and value.value is defined and value.value == option.value %}checked{% endif %} {% if element.required and loop.first %}required{% endif %}>
                            <label class="form-check-label" for="fields-{{ field.handle }}-{{ loop.index }}">
                              {{ option.label }}
                            </label>
                          </div>
                        {% endfor %}
                      </div>

                    {# Checkboxes #}
                    {% elseif fieldClass == 'craft\\fields\\Checkboxes' %}
                      <div class="mt-2">
                        {% for option in field.options %}
                          {% set isChecked = false %}
                          {% if value %}
                            {% set iterableValue = value|length ? value : [] %}
                            {% for val in iterableValue %}
                              {% if val.value is defined and val.value == option.value %}{% set isChecked = true %}{% endif %}
                            {% endfor %}
                          {% endif %}
                          <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="fields[{{ field.handle }}][]" value="{{ option.value }}" id="fields-{{ field.handle }}-{{ loop.index }}" {% if isChecked %}checked{% endif %}>
                            <label class="form-check-label" for="fields-{{ field.handle }}-{{ loop.index }}">
                              {{ option.label }}
                            </label>
                          </div>
                        {% endfor %}
                      </div>

                    {# Button Group #}
                    {% elseif fieldClass == 'craft\\fields\\ButtonGroup' %}
                      <div class="btn-group mt-2" role="group" aria-label="{{ field.name }}">
                        {% for option in field.options %}
                          <input type="radio" class="btn-check" name="fields[{{ field.handle }}]" id="fields-{{ field.handle }}-{{ loop.index }}" autocomplete="off" value="{{ option.value }}" {% if value and value.value is defined and value.value == option.value %}checked{% endif %} {% if element.required and loop.first %}required{% endif %}>
                          <label class="btn btn-outline-primary" for="fields-{{ field.handle }}-{{ loop.index }}">{{ option.label }}</label>
                        {% endfor %}
                      </div>

                    {# Date Field #}
                    {% elseif fieldClass == 'craft\\fields\\Date' %}
                      {% set hasTime = field.showTime is defined ? field.showTime : false %}
                      {% set dateType = hasTime ? 'datetime-local' : 'date' %}
                      {% set dateValue = '' %}
                      {% if value %}
                        {% set dateValue = hasTime ? value|date('Y-m-d\\TH:i') : value|date('Y-m-d') %}
                      {% endif %}
                      <input type="{{ dateType }}" 
                             id="fields-{{ field.handle }}" 
                             name="fields[{{ field.handle }}]" 
                             class="form-control {% if entry.hasErrors(field.handle) %}is-invalid{% endif %}"
                             value="{{ dateValue }}"
                             {% if element.required %}required{% endif %}>

                    {# Color Field #}
                    {% elseif fieldClass == 'craft\\fields\\Color' %}
                      <input type="color" 
                             id="fields-{{ field.handle }}" 
                             name="fields[{{ field.handle }}]" 
                             class="form-control form-control-color {% if entry.hasErrors(field.handle) %}is-invalid{% endif %}"
                             value="{{ value|default('#000000') }}"
                             title="Choose your color"
                             {% if element.required %}required{% endif %}>

                    {# Asset Field #}
                    {% elseif fieldClass == 'craft\\fields\\Assets' %}
                      {% set assetsArray = value is iterable ? value : (value and value.all is defined ? value.all() : []) %}
                      {% if assetsArray|length %}
                        <ul class="list-group mb-2">
                          {% for asset in assetsArray %}
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                              <div>
                                {% if asset.kind == 'image' %}
                                  <img src="{{ asset.getUrl() }}" alt="{{ asset.title }}" class="img-thumbnail me-2" style="max-height: 40px;">
                                {% else %}
                                  <i class="bi bi-file-earmark me-2"></i>
                                {% endif %}
                                {{ asset.title }}
                              </div>
                              <span class="badge text-bg-secondary rounded-pill">{{ asset.size|filesize }}</span>
                            </li>
                          {% endfor %}
                        </ul>
                      {% endif %}
                      <input type="file" 
                             id="fields-{{ field.handle }}" 
                             name="fields[{{ field.handle }}][]" 
                             class="form-control {% if entry.hasErrors(field.handle) %}is-invalid{% endif %}"
                             {% set isMultiple = field.maxRelations is defined ? field.maxRelations != 1 : true %}
                             {% if isMultiple %}multiple{% endif %}
                             {% if element.required and not assetsArray|length %}required{% endif %}>
                      <div class="form-text">Uploading new files will replace existing ones on save.</div>

                    {# Rich Text (CKEditor / Redactor) #}
                    {% elseif fieldClass == 'craft\\ckeditor\\Field' or fieldClass == 'craft\\redactor\\Field' %}
                      <textarea id="fields-{{ field.handle }}" 
                                name="fields[{{ field.handle }}]" 
                                class="form-control richtext {% if entry.hasErrors(field.handle) %}is-invalid{% endif %}"
                                rows="6"
                                {% if element.required %}required{% endif %}>{{ value }}</textarea>

                    {# Fallback #}
                    {% else %}
                      <div class="alert alert-secondary mt-1">
                        <small>Unsupported field type: {{ fieldClass }} (Handle: {{ field.handle }})</small>
                      </div>
                    {% endif %}
                  </div>
                  {% endif %}
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
        
      </div>
    {% endfor %}
  </div>
  {% endif %}
{% endmacro %}
